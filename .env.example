# ============================================================
# ACQUAXCONTROL — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o .env no GitHub!
# ============================================================

# === BANCO DE DADOS (MongoDB — Digital Ocean, banco principal) ===
# Formato: mongodb+srv://USUARIO:SENHA@HOST/BANCO?authSource=admin&tls=true
DATABASE_URL="mongodb+srv://doadmin:SENHA@db-mongodb-acquaxc-nyc3-81713-2abc9433.mongo.ondigitalocean.com/AcquaXControl_PRD?authSource=admin&tls=true"

# === AUTENTICAÇÃO ===
# Gere uma chave forte: openssl rand -base64 64
JWT_SECRET="GERE_UMA_CHAVE_FORTE_AQUI_COM_64_CHARS_MINIMO"

# === URLs DA APLICAÇÃO ===
# Produção:
NEXT_PUBLIC_BASE_URL="https://acquaxcontrol.com.br"
NEXT_PUBLIC_API_URL="https://acquaxcontrol.com.br/api"
# Desenvolvimento local:
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# === EMAIL (Nodemailer — recuperação de senha) ===
# Use uma "Senha de App" do Gmail (não sua senha normal)
# Como criar: myaccount.google.com → Segurança → Senhas de App
EMAIL_USER="seu-email@gmail.com"
EMAIL_PASS="xxxx xxxx xxxx xxxx"

# === GROUP LINK MQTT (Integração de leituras IoT) ===
# Broker/credenciais (TLS com certificado)
GROUPLINK_MQTT_HOST="mqtt.grouplinknetwork.com"
GROUPLINK_MQTT_PORT="8883"
GROUPLINK_MQTT_CLIENT_ID="seu-org-name"
GROUPLINK_MQTT_TOPIC="message/seu-org-name"
# Opcional: múltiplos tópicos para sincronização manual (/sync), separados por vírgula, ; ou quebra de linha
# GROUPLINK_MQTT_TOPICS="message/topico-1,message/topico-2"

# Caminhos absolutos para os arquivos de certificado recebidos da Group Link
# - CA: grouplink-ca.crt
# - CERT: certificado do cliente (.crt)
# - KEY: chave privada usada no CSR (.key)
GROUPLINK_MQTT_CA_PATH="/secure-certs/grouplink-ca.crt"
GROUPLINK_MQTT_CERT_PATH="/secure-certs/private.crt"
GROUPLINK_MQTT_KEY_PATH="/secure-certs/private.key"

# Opcional (recomendado no Vercel): informar certificados diretamente por ENV
# Prioridade de leitura no código:
# 1) *_B64 ou *_BASE64 ou *_PEM_B64  (conteúdo PEM em base64)
# 2) *_PEM      (conteúdo PEM em texto, com \n)
# 3) *_PATH     (arquivo local)
#
# Exemplos:
# GROUPLINK_MQTT_CA_B64="LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0t..."
# GROUPLINK_MQTT_CERT_B64="LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0t..."
# GROUPLINK_MQTT_KEY_B64="LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t..."

# Segurança da rota de sincronização agendada
# Envie no header: x-grouplink-sync-secret
GROUPLINK_SYNC_SECRET="defina-um-segredo-forte-aqui"

# Tuning da janela de coleta MQTT (a sincronização é disparada 1x ao dia)
GROUPLINK_MQTT_CONNECT_TIMEOUT_MS="12000"
GROUPLINK_MQTT_MAX_COLLECTION_MS="45000"
GROUPLINK_MQTT_IDLE_TIMEOUT_MS="8000"
GROUPLINK_MQTT_MAX_MESSAGES="5000"
