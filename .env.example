# Banco de dados MongoDB Atlas
DATABASE_URL="mongodb+srv://usuario:senha@cluster.mongodb.net/acquax?appName=acquaxfield"

# JWT Secret para autenticação (use uma string longa e aleatória)
JWT_SECRET="sua-chave-secreta-jwt-aqui"

# URL da aplicação (preencher com a URL do Vercel após deploy)
NEXT_PUBLIC_BASE_URL="https://seu-projeto.vercel.app"
NEXT_PUBLIC_API_URL="https://seu-projeto.vercel.app/api"

# Email (nodemailer) - para recuperação de senha
EMAIL_USER="seu-email@gmail.com"
EMAIL_PASS="sua-senha-de-app-gmail"
