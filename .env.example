# ============================================================
# ACQUAXCONTROL — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o .env no GitHub!
# ============================================================

# === BANCO DE DADOS (MongoDB — Digital Ocean, banco principal) ===
# Formato: mongodb+srv://USUARIO:SENHA@HOST/BANCO?authSource=admin&tls=true
DATABASE_URL="mongodb+srv://doadmin:SENHA@db-mongodb-acquaxc-nyc3-81713-2abc9433.mongo.ondigitalocean.com/AcquaXControl_PRD?authSource=admin&tls=true"

# === AUTENTICAÇÃO ===
# Gere uma chave forte: openssl rand -base64 64
JWT_SECRET="GERE_UMA_CHAVE_FORTE_AQUI_COM_64_CHARS_MINIMO"

# === URLs DA APLICAÇÃO ===
# Produção:
NEXT_PUBLIC_BASE_URL="https://acquaxcontrol.com.br"
NEXT_PUBLIC_API_URL="https://acquaxcontrol.com.br/api"
# Desenvolvimento local:
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# === EMAIL (Nodemailer — recuperação de senha) ===
# Use uma "Senha de App" do Gmail (não sua senha normal)
# Como criar: myaccount.google.com → Segurança → Senhas de App
EMAIL_USER="seu-email@gmail.com"
EMAIL_PASS="xxxx xxxx xxxx xxxx"

# === INTEGRAÇÃO GROUP LINK (GL) — Importação S3 ===
# A GL deposita arquivos CSV no S3; o cron (07h e 19h BRT) baixa e importa as leituras
GL_S3_BUCKET="acquax-grouplink-batch-115655017755-us-east-2-an"
GL_S3_REGION="us-east-2"
GL_S3_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
GL_S3_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
# Prefixo base do path no S3 (padrão: events → events/{ano}/{mes}/{dia}/*.csv.gz)
GL_S3_PATH_PREFIX="events"

# === VERCEL CRON JOBS ===
# Segredo compartilhado entre Vercel e a rota /api/cron/gl-import
# Vercel envia automaticamente: Authorization: Bearer <CRON_SECRET>
# Gere com: openssl rand -base64 32
CRON_SECRET="seu-segredo-aqui"
