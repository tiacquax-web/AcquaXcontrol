# ============================================================
# ACQUAXCONTROL — VARIAVEIS DE AMBIENTE (STAGING)
# Copie este arquivo para .env.staging e preencha os valores reais
# NUNCA commite o .env.staging com segredos no GitHub!
# ============================================================

# === BANCO DE DADOS (MongoDB — ambiente de staging) ===
# Formato: mongodb+srv://USUARIO:SENHA@HOST/BANCO?authSource=admin&tls=true
DATABASE_URL="mongodb+srv://USUARIO:SENHA@HOST/AcquaXControl_STG?authSource=admin&tls=true"

# === AUTENTICACAO ===
# Gere uma chave forte: openssl rand -base64 64
JWT_SECRET="GERE_UMA_CHAVE_FORTE_AQUI_COM_64_CHARS_MINIMO"

# === URLs DA APLICACAO (STAGING) ===
NEXT_PUBLIC_BASE_URL="https://staging.acquaxcontrol.com.br"
NEXT_PUBLIC_API_URL="https://staging.acquaxcontrol.com.br/api"

# === EMAIL (Nodemailer — recuperacao de senha) ===
EMAIL_USER="seu-email@gmail.com"
EMAIL_PASS="xxxx xxxx xxxx xxxx"

# === OPCIONAL ===
# Ative somente se quiser registrar SW em dev local:
# NEXT_PUBLIC_ENABLE_SW_DEV="true"
