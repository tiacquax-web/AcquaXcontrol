  dealershipConsumptionTax2   Float?       @default(0.000)   // Não usar
  dealershipConsumptionTax3   Float?       @default(0.000)   // Não usar
  dealershipConsumptionTax4   Float?       @default(0.000)   // Não usar
  dealershipConsumptionTax5   Float?       @default(0.000)   // Não usar
  dealershipConsumptionTax6   Float?       @default(0.000)   // Não usar
  consumptionTax1             Float?       @default(0.000)   // Não usar
  consumptionTax2             Float?       @default(0.000)   // Não usar
  consumptionTax3             Float?       @default(0.000)   // Não usar
  consumptionTax4             Float?       @default(0.000)   // Não usar
  consumptionTax5             Float?       @default(0.000)   // Não usar
  consumptionTax6             Float?       @default(0.000)   // Não usar

  // Cost details
