  dealershipCostTax2          Float?       @default(0.000)   // Não usar
  dealershipCostTax3          Float?       @default(0.000)   // Não usar
  dealershipCostTax4          Float?       @default(0.000)   // Não usar
  dealershipCostTax5          Float?       @default(0.000)   // Não usar
  dealershipCostTax6          Float?       @default(0.000)   // Não usar
  dealershipCost              Float        @default(0.00)    // Custo da Concessionária em Reais
  consumptionValue            Float        @default(0.000)   // Valor do Consumo
  sewageValue                 Float        @default(0.000)   // Valor do Esgoto
  totalValue                  Float        @default(0.000)   // Conta Total
  diffCost                    Float        @default(0.000)   // É usado para "Área Comum" em reais
  kiteCarTax                  Float        @default(0.000)   // Valor do m³
  kiteCarTotal                Float        @default(0.000)   // Valor total do Carro Pipa
  valuePerKiteCar             Float        @default(0.000)   // Valor por Caminhão
  kiteCarCostUnits            Float        @default(0.000)   // Valor Carro Pipa das Unidades

  // Calculation details
  consumptionCalculation      String       @default("Consumo Real")              // Manter padrão (não usar o campo na criação nem edição)
  typeMinimumValue            String       @default("Pré Estabelecido")          // Manter padrão (não usar o campo na criação nem edição)
  minimumValue                Float        @default(0.000)                       // Manter padrão (não usar o campo na criação nem edição)
  fareType                    String       @default("Metro Cúbico Médio")        // Manter padrão (não usar o campo na criação nem edição)
