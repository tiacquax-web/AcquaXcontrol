// =====================================================
// SISTEMA DE MEDIÇÃO DE NÍVEL DE RESERVATÓRIOS
// =====================================================

// Enum para tipos de reservatório
enum ReservoirType {
  WATER_TANK      // Caixa d'água
  CISTERN         // Cisterna
  POOL            // Piscina
  FOUNTAIN        // Chafariz
  EMERGENCY_TANK  // Reserva de emergência
  TREATMENT_TANK  // Tanque de tratamento
}

// Model para Reservatórios
model Reservoir {
  id                    String       @id @map("_id") @default(uuid())
  name                  String       // "Reservatório Superior"
  telegramChannel       String       // "LOG Acqua X Brasil"
  type                  ReservoirType @default(WATER_TANK)
  
  // Vínculo com condomínio (opcional inicialmente)
  complexId             String?
  complex               Complex?     @relation(fields: [complexId], references: [id])
  
  // Campos desnormalizados para performance (seguindo padrão do sistema)
  companyId             String?
  
  // Configurações específicas
  capacity              Float?       // Capacidade total em m³
  minLevel              Float?       // Nível mínimo de alerta
  maxLevel              Float?       // Nível máximo
  
  // Metadados
  description           String?
  location              String?      // Localização física
  installationDate      DateTime?
  
  // Sistema de auditoria (seguindo padrão)
  createdAt             DateTime     @default(now()) @db.Timestamp
  updatedAt             DateTime     @updatedAt @db.Timestamp
  deletedAt             DateTime?    @db.Timestamp
  
  createdByUserId       String?
  createdByUser         User?        @relation("ReservoirCreatedByUser", fields: [createdByUserId], references: [id])
  updatedByUserId       String?
  updatedByUser         User?        @relation("ReservoirUpdatedByUser", fields: [updatedByUserId], references: [id])
  
  // Relacionamentos
  readings              ReservoirReading[]
  
  // Índices para performance
  @@unique([name, telegramChannel, deletedAt], name: "unique_reservoir_channel")
  @@index([complexId])
  @@index([telegramChannel])
  @@index([type])
  @@index([deletedAt])
  @@index([complexId, deletedAt, name]) // Índice composto
  
  @@map("Reservoirs")
}

// Model para Leituras dos Reservatórios
model ReservoirReading {
  id                    String       @id @map("_id") @default(uuid())
  
  // Vínculo com reservatório
  reservoirId           String
  reservoir             Reservoir    @relation(fields: [reservoirId], references: [id])
  
  // Dados da leitura
  level                 Float        // Nível em metros
  rawLevel              Float?       // Nível bruto do sensor
  distance              Float?       // Distância medida pelo sensor
  
  // Dados ambientais
  temperature           Float?       // Temperatura
  temperatureSecondary  Float?       // Segunda leitura de temperatura
  
  // Dados do dispositivo
  batteryVoltage        Float?       // Tensão da bateria
  batteryVoltageSecondary Float?     // Segunda leitura de bateria
  
  // Dados de conectividade
  signalQuality         Float?       // Qualidade do sinal (SNR)
  signalStrength        Float?       // Força do sinal (RSSI)
  gatewaySignalQuality  Float?       // SNR do gateway
  gatewaySignalStrength Float?       // RSSI do gateway
  
  // Velocidades e outros dados técnicos
  speed1                Float?
  speed2                Float?
  
  // Dados temporais
  readingDate           DateTime     // Data/hora da leitura
  receivedAt            DateTime     @default(now()) @db.Timestamp // Data/hora de recebimento
  
  // Dados do telegram (para auditoria)
  telegramMessageId     String?      // ID da mensagem do Telegram
  telegramChannelName   String?      // Nome do canal
  telegramDeviceName    String?      // Nome do dispositivo na mensagem
  
  // Processamento
  isProcessed           Boolean      @default(false)
  processingErrors      String?      // Erros durante processamento
  
  // Sistema de auditoria
  createdAt             DateTime     @default(now()) @db.Timestamp
  updatedAt             DateTime     @updatedAt @db.Timestamp
  deletedAt             DateTime?    @db.Timestamp
  
  createdByUserId       String?
  createdByUser         User?        @relation("ReservoirReadingCreatedByUser", fields: [createdByUserId], references: [id])
  updatedByUserId       String?
  updatedByUser         User?        @relation("ReservoirReadingUpdatedByUser", fields: [updatedByUserId], references: [id])
  
  // Índices para performance
  @@index([reservoirId])
  @@index([readingDate])
  @@index([receivedAt])
  @@index([isProcessed])
  @@index([deletedAt])
  @@index([reservoirId, readingDate]) // Para consultas temporais por reservatório
  @@index([readingDate, deletedAt])   // Para consultas temporais globais
  
  @@map("ReservoirReadings")
}

// ### AGENDA E TAREFAS AGENDADAS ###

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  METER_READING
  MAINTENANCE
  INSPECTION
  OTHER
}

enum OverrideType {
  CANCEL      // Cancela a ocorrência
  RESCHEDULE  // Move para outra data/hora
  MODIFY      // Altera detalhes mas mantém data
}

model ScheduledTask {
  id                        String    @id @map("_id") @default(uuid())
  
  // Informações básicas
  title                     String
  description               String?
  status                    TaskStatus @default(PENDING)
  priority                  TaskPriority @default(HIGH)
  
  // Agendamento
  scheduledDate             DateTime
  completedAt               DateTime?
  
  // Contexto da tarefa
  taskType                  TaskType
  contextId                 String    // ID do apartamento, medidor, etc.
  contextType               ContextType
  
  // Dados específicos da leitura (se aplicável)
  meterId                   String?
  apartmentId               String?
  
  // Campos desnormalizados para permissões e filtros
  companyId                 String?   // ID da empresa (desnormalizado)
  companyName               String?   // Nome da empresa (desnormalizado)
  complexId                 String?   // ID do complexo (desnormalizado)
  complexName               String?   // Nome do complexo (desnormalizado)
  complexSocialName         String?   // Nome social do complexo (desnormalizado)
  blockId                   String?   // ID do bloco (desnormalizado)
  blockName                 String?   // Nome do bloco (desnormalizado)
  apartmentName             String?   // Nome do apartamento (desnormalizado)
  meterRegister             String?   // Registro do medidor (desnormalizado)
  
  // Relacionamentos
  assignedToUserId          String?
  assignedToUser            User?     @relation("AssignedTasks", fields: [assignedToUserId], references: [id])
  
  // Auditoria
  createdAt                 DateTime  @default(now()) @db.Timestamp
  updatedAt                 DateTime  @updatedAt @db.Timestamp
  deletedAt                 DateTime? @db.Timestamp
  
  createdByUserId           String?
  createdByUser             User?     @relation("CreatedTasks", fields: [createdByUserId], references: [id])
  updatedByUserId           String?
  updatedByUser             User?     @relation("UpdatedTasks", fields: [updatedByUserId], references: [id])
  
  // Relacionamento com leituras executadas a partir desta tarefa
  readings                  Reading[] @relation("ScheduledTaskReadings")
  
  // EXTENSÃO RRULE: Campos para suporte a tarefas recorrentes
  recurringScheduleId       String?   // Se veio de RRULE
  originalRRuleDate         DateTime? // Data original do RRULE (antes de overrides)
  isFromRecurring           Boolean   @default(false) // Flag para identificar origem
  
  // Relacionamento com agenda recorrente
  recurringSchedule         RecurringSchedule? @relation("RecurringScheduleTasks", fields: [recurringScheduleId], references: [id])
  
  @@map("ScheduledTasks")
  @@index([assignedToUserId])
  @@index([scheduledDate])
  @@index([status])
  @@index([contextId, contextType])
  @@index([companyId])
  @@index([complexId])
  @@index([taskType])
  @@index([deletedAt])
  @@index([recurringScheduleId]) // Novo índice para RRULE
  @@index([isFromRecurring])     // Novo índice para RRULE
}

// NOVOS MODELOS RRULE

model RecurringSchedule {
  id            String @id @map("_id") @default(uuid())
  title         String
  description   String?
  taskType      TaskType
  priority      TaskPriority @default(HIGH)
  
  // Dados desnormalizados para performance e permissões
  companyId     String   // ID da empresa
  companyName   String   // Nome da empresa
  complexId     String   // ID do complexo
  complexName   String   // Nome do complexo
  complexSocialName String? // Nome social do complexo
  blockId       String?  // ID do bloco (opcional)
  blockName     String?  // Nome do bloco (opcional)
  apartmentId   String?  // ID do apartamento (opcional)
  apartmentName String?  // Nome do apartamento (opcional)
  meterId       String?  // ID do medidor (opcional)
  meterRegister String?  // Registro do medidor (opcional)
  
  // RRULE - Configuração de recorrência
  rrule         String     // Ex: "FREQ=MONTHLY;BYMONTHDAY=15"
  startDate     DateTime   // Data base para cálculo das ocorrências
  endDate       DateTime?  // Data final opcional (UNTIL do RRULE)
  timeOfDay     String     // Horário fixo (ex: "09:00")
  
  // Controle
  isActive      Boolean @default(true)
  
  // Auditoria
  createdAt     DateTime @default(now()) @db.Timestamp
  updatedAt     DateTime @updatedAt @db.Timestamp
  deletedAt     DateTime? @db.Timestamp
  
  createdByUserId String
  updatedByUserId String?
  
  // Relacionamentos
  createdByUser   User @relation("RecurringScheduleCreator", fields: [createdByUserId], references: [id])
  updatedByUser   User? @relation("RecurringScheduleUpdater", fields: [updatedByUserId], references: [id])
  
  // Tarefas geradas a partir desta agenda recorrente
  scheduledTasks  ScheduledTask[] @relation("RecurringScheduleTasks")
  
  // Exceções e alterações para datas específicas
  overrides       ScheduleOverride[] @relation("RecurringScheduleOverrides")
  
  @@map("RecurringSchedules")
  @@index([companyId])
  @@index([complexId])
  @@index([blockId])
  @@index([apartmentId])
  @@index([meterId])
  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
  @@index([taskType])
  @@index([deletedAt])
}

model ScheduleOverride {
  id                  String @id @map("_id") @default(uuid())
  recurringScheduleId String // Referência à agenda recorrente
  
  // Data específica que está sendo modificada
  originalDate        DateTime  // Data original que seria gerada pelo RRULE
  
  // Tipo de modificação
  overrideType        OverrideType
  
  // Campos para RESCHEDULE
  newDate             DateTime?  // Nova data (se for reagendamento)
  newTime             String?    // Novo horário (ex: "14:00")
  
  // Campos para MODIFY
  newTitle            String?    // Novo título
  newDescription      String?    // Nova descrição
  newPriority         TaskPriority? // Nova prioridade
  
  // Motivo da alteração
  reason              String?
  
  // Auditoria
  createdAt           DateTime @default(now()) @db.Timestamp
  createdByUserId     String
  
  // Relacionamentos
  recurringSchedule   RecurringSchedule @relation("RecurringScheduleOverrides", fields: [recurringScheduleId], references: [id])
  createdByUser       User @relation("ScheduleOverrideCreator", fields: [createdByUserId], references: [id])
  
  @@map("ScheduleOverrides")
  @@index([recurringScheduleId])
  @@index([originalDate])
  @@index([overrideType])
  @@index([createdAt])
}
