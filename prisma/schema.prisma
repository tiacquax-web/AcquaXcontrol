  @@index([companyId, deletedAt])
  @@index([dealershipId, deletedAt])
  @@index([yearRef, monthRef, deletedAt])
  @@index([readingDate, deletedAt])
  @@index([type, deletedAt])
  @@index([deletedAt])
  
  // Índices otimizados para consultas com filtros de data range
  @@index([readingDate, complexId, deletedAt])
  @@index([readingDate, dealershipId, deletedAt])
  
  // Índices compostos para consultas complexas (JOIN com ApartmentConsumptionReport)
  @@index([complexId, readingDate, deletedAt])
  @@index([dealershipId, readingDate, deletedAt])
  @@index([type, readingDate, deletedAt])
}

