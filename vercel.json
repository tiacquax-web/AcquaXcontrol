{
  "buildCommand": "npx prisma generate && next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_API_URL": "/api"
  },
  "crons": [
    {
      "path": "/api/cron/gl-import",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/gl-import",
      "schedule": "0 22 * * *"
    }
  ]
}




